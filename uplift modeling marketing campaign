 threshold\n","→ Area between model and random = Qini coefficient (higher = better)\n","\n"]}],"source":["def compute_qini_curve(uplift_scores, treatment, outcome):\n","    \"\"\"\n","    Qini curve: measures cumulative incremental conversions\n","    as we contact increasing % of customers ranked by uplift score.\n","    \n","    A good uplift model concentrates Persuadables at the top.\n","    \"\"\"\n","    df_q = pd.DataFrame({\n","        'uplift'    : uplift_scores,\n","        'treatment' : treatment,\n","        'outcome'   : outcome\n","    }).sort_values('uplift', ascending=False).reset_index(drop=True)\n","\n","    n = len(df_q)\n","    n_treatment = df_q['treatment'].sum()\n","    n_control   = n - n_treatment\n","\n","    qini_x, qini_y = [0], [0]\n","    cumulative_incremental = 0\n","\n","    for i in range(1, n + 1):\n","        subset = df_q.iloc[:i]\n","        n_t = subset['treatment'].sum()\n","        n_c = i - n_t\n","\n","        if n_t > 0 and n_c > 0:\n","            conv_t = subset[subset['treatment']==1]['outcome'].sum() / n_t\n","            conv_c = subset[subset['treatment']==0]['outcome'].sum() / n_c\n","            incremental = (conv_t - conv_c) * n_t\n","        else:\n","            incremental = 0\n","\n","        qini_x.append(i / n * 100)\n","        qini_y.append(incremental)\n","\n","    return np.array(qini_x), np.array(qini_y)\n","\n","\n","# Compute Qini curves\n","x_t, y_t = compute_qini_curve(uplift_tlearner, t_test.values, y_test.values)\n","x_s, y_s = compute_qini_curve(uplift_slearner, t_test.values, y_test.values)\n","\n","# Random baseline — targeting randomly\n","x_rand = np.linspace(0, 100, len(x_t))\n","y_rand = np.linspace(0, y_t[-1], len(y_t))\n","\n","plt.figure(figsize=(10, 6))\n","plt.plot(x_t, y_t, label='T-Learner', color='steelblue', linewidth=2)\n","plt.plot(x_s, y_s, label='S-Learner', color='tomato', linewidth=2)\n","plt.plot(x_rand, y_rand, label='Random Targeting', \n","         color='gray', linestyle='--', linewidth=1.5)\n","\n","plt.title('Qini Curve — Uplift Model Comparison', \n","          fontsize=14, fontweight='bold')\n","plt.xlabel('% of Customers Targeted (ranked by uplift score)')\n","plt.ylabel('Cumulative Incremental Conversions')\n","plt.legend()\n","plt.grid(alpha=0.3)\n","plt.tight_layout()\n","plt.show()\n","\n","print(\"\"\"\n","HOW TO READ THE QINI CURVE:\n","→ X-axis: % of customers contacted, ranked by uplift score (highest first)\n","→ Y-axis: cumulative incremental conversions gained\n","→ Above random line = model adds value over random targeting\n","→ Peak of curve = optimal targeting threshold\n","→ Area between model and random = Qini coefficient (higher = better)\n","\"\"\")"]},{"cell_type":"code","execution_count":14,"id":"9e86a71e","metadata":{"execution":{"iopub.execute_input":"2026-05-13T08:48:35.986497Z","iopub.status.busy":"2026-05-13T08:48:35.985501Z","iopub.status.idle":"2026-05-13T08:48:35.996375Z","shell.execute_reply":"2026-05-13T08:48:35.994375Z"},"papermill":{"duration":0.02326,"end_time":"2026-05-13T08:48:35.998843+00:00","exception":false,"start_time":"2026-05-13T08:48:35.975583+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["==================================================\n","QINI COEFFICIENTS\n","==================================================\n","T-Learner Qini: 162.1114\n","S-Learner Qini: 130.1710\n","\n","Winner: T-Learner\n","\n","Qini coefficient interpretation:\n","→ 0       = no better than random targeting\n","→ Higher  = model concentrates Persuadables better\n","→ Negative = model is WORSE than random (avoid)\n","\n"]},{"name":"stderr","output_type":"stream","text":["/tmp/ipykernel_16/56965377.py:6: DeprecationWarning: `trapz` is deprecated. Use `trapezoid` instead, or one of the numerical integration functions in `scipy.integrate`.\n","  area_model  = np.trapz(y, x)\n","/tmp/ipykernel_16/56965377.py:7: DeprecationWarning: `trapz` is deprecated. Use `trapezoid` instead, or one of the numerical integration functions in `scipy.integrate`.\n","  area_random = np.trapz(y_rand, x)\n"]}],"source":["def qini_coefficient(x, y, y_rand):\n","    \"\"\"\n","    Area between model curve and random baseline.\n","    Higher = better uplift model.\n","    \"\"\"\n","    area_model  = np.trapz(y, x)\n","    area_random = np.trapz(y_rand, x)\n","    return area_model - area_random\n","\n","qini_t = qini_coefficient(x_t, y_t, y_rand)\n","qini_s = qini_coefficient(x_s, y_s, y_rand)\n","\n","print(\"=\" * 50)\n","print(\"QINI COEFFICIENTS\")\n","print(\"=\" * 50)\n","print(f\"T-Learner Qini: {qini_t:.4f}\")\n","print(f\"S-Learner Qini: {qini_s:.4f}\")\n","print(f\"\\nWinner: {'T-Learner' if qini_t > qini_s else 'S-Learner'}\")\n","print(\"\"\"\n","Qini coefficient interpretation:\n","→ 0       = no better than random targeting\n","→ Higher  = model concentrates Persuadables better\n","→ Negative = model is WORSE than random (avoid)\n","\"\"\")"]},{"cell_type":"code","execution_count":15,"id":"7890d739","metadata":{"execution":{"iopub.execute_input":"2026-05-13T08:48:36.018294Z","iopub.status.busy":"2026-05-13T08:48:36.017382Z","iopub.status.idle":"2026-05-13T08:48:36.509979Z","shell.execute_reply":"2026-05-13T08:48:36.508823Z"},"papermill":{"duration":0.505652,"end_time":"2026-05-13T08:48:36.513029+00:00","exception":false,"start_time":"2026-05-13T08:48:36.007377+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["==================================================\n","OPTIMAL TARGETING THRESHOLD — T-Learner\n","==================================================\n","Target top: 85.4% of customers\n","Max incremental conversions: 3.9\n","Uplift score cutoff: 0.0000\n","\n","Customers to target: 7295 out of 8539\n","Customers to AVOID:  1244\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 1000x600 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["# Find