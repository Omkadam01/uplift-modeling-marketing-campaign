rol', 'Treatment']].plot(\n","    kind='bar', ax=axes[0],\n","    color=['steelblue', 'tomato'],\n","    edgecolor='black'\n",")\n","axes[0].set_title('Conversion by History Segment & Group', fontweight='bold')\n","axes[0].set_ylabel('Conversion Rate')\n","axes[0].tick_params(axis='x', rotation=45)\n","\n","hist_conv['Uplift'].mul(100).plot(\n","    kind='bar', ax=axes[1],\n","    color='green', edgecolor='black'\n",")\n","axes[1].set_title('Uplift by History Segment', fontweight='bold')\n","axes[1].set_ylabel('Uplift (%)')\n","axes[1].axhline(0, color='black', linestyle='--')\n","axes[1].tick_params(axis='x', rotation=45)\n","\n","plt.suptitle('Uplift Concentration by Purchase History',\n","             fontsize=13, fontweight='bold')\n","plt.tight_layout()\n","plt.show()\n","\n","print(\"\\nUplift by history segment:\")\n","print(hist_conv['Uplift'].mul(100).round(3))\n","print(\"\\nNegative uplift = Sleeping Dogs (intervention HURTS these customers)\")"]},{"cell_type":"code","execution_count":6,"id":"7915bec1","metadata":{"execution":{"iopub.execute_input":"2026-05-13T08:48:14.713618Z","iopub.status.busy":"2026-05-13T08:48:14.712942Z","iopub.status.idle":"2026-05-13T08:48:14.943061Z","shell.execute_reply":"2026-05-13T08:48:14.941817Z"},"papermill":{"duration":0.24201,"end_time":"2026-05-13T08:48:14.94566+00:00","exception":false,"start_time":"2026-05-13T08:48:14.70365+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Features available:\n","recency              int64\n","history_segment     object\n","history            float64\n","mens                 int64\n","womens               int64\n","zip_code            object\n","newbie               int64\n","channel             object\n","conversion           int64\n","treatment            int64\n","dtype: object\n","\n","Categorical columns:\n","['history_segment', 'zip_code', 'channel']\n"]}],"source":["from sklearn.preprocessing import LabelEncoder\n","\n","# Work on clean copy\n","data = df_binary.copy()\n","\n","# Drop outcome-related columns — these are POST-treatment, not features\n","# Using them would cause data leakage\n","data.drop(columns=['segment', 'visit', 'spend'], inplace=True)\n","\n","print(\"Features available:\")\n","print(data.dtypes)\n","print(\"\\nCategorical columns:\")\n","print(data.select_dtypes('object').columns.tolist())"]},{"cell_type":"code","execution_count":7,"id":"3bb0ff76","metadata":{"execution":{"iopub.execute_input":"2026-05-13T08:48:14.960032Z","iopub.status.busy":"2026-05-13T08:48:14.959349Z","iopub.status.idle":"2026-05-13T08:48:15.000832Z","shell.execute_reply":"2026-05-13T08:48:14.99944Z"},"papermill":{"duration":0.051442,"end_time":"2026-05-13T08:48:15.003105+00:00","exception":false,"start_time":"2026-05-13T08:48:14.951663+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Feature engineering complete.\n","Final shape: (42693, 14)\n","\n","Features: ['recency', 'history_segment', 'history', 'mens', 'womens', 'zip_code', 'newbie', 'channel', 'RecencyScore', 'IsHighValue', 'IsMidValue', 'EngagementScore']\n"]}],"source":["# Encode categoricals\n","le = LabelEncoder()\n","cat_cols = data.select_dtypes('object').columns.tolist()\n","for col in cat_cols:\n","    data[col] = le.fit_transform(data[col])\n","\n","# Engineer meaningful features\n","# Recency score — lower recency = more recent = higher engagement\n","data['RecencyScore']      = 1 / (data['recency'] + 1)\n","\n","# High value flag — history > 500 showed strongest uplift\n","data['IsHighValue']       = (data['history'] > 500).astype(int)\n","\n","# Mid value flag — $200-500 showed negative uplift (Sleeping Dogs)\n","data['IsMidValue']        = ((data['history'] >= 200) & \n","                              (data['history'] <= 500)).astype(int)\n","\n","# Engagement score — recency + history combined\n","data['EngagementScore']   = data['history'] / (data['recency'] + 1)\n","\n","print(\"Feature engineering complete.\")\n","print(f\"Final shape: {data.shape}\")\n","print(f\"\\nFeatures: {data.drop(columns=['conversion','treatment']).columns.tolist()}\")"]},{"cell_type":"code","execution_count":8,"id":"f821d33e","metadata":{"execution":{"iopub.execute_input":"2026-05-13T08:48:15.018271Z","iopub.status.busy":"2026-05-13T08:48:15.017129Z","iopub.status.idle":"2026-05-13T08:48:15.194735Z","shell.execute_reply":"2026-05-13T08:48:15.193316Z"},"papermill":{"duration":0.187748,"end_time":"2026-05-13T08:48:15.196989+00:00","exception":false,"start_time":"2026-05-13T08:48:15.009241+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Train size: (34154, 12)\n","Test size:  (8539, 12)\n","\n","Treatment rate in train: 0.501\n","Treatment rate in test:  0.501\n"]}],"source":["from sklearn.model_selection import train_test_split\n","\n","features = [c for c in data.columns \n","            if c not in ['conversion', 'treatment']]\n","\n","X = data[features]\n","y = data['conversion']\n","t = data['treatment']\n","\n","X_train, X_test, y_train, y_test, t_train, t_test = train_test_split(\n","    X, y, t,\n","    test_size=0.2,\n","    random_state=42,\n","    stratify=t        # preserve treatment ratio\n",")\n","\n","print(f\"Train size: {X_train.shape}\")\n","print(f\"Test size:  {X_test.shape}\")\n","print(f\"\\nTreatment rate in train: {t_train.mean():.3f}\")\n","print(f\"Treatment rate in test:  {t_test.mean():.3f}\")"]},{"cell_type":"code","execution_count":9,"id":"c1474c21","metadata":{"execution":{"iopub.execute_input":"2026-05-13T08:48:15.212046Z","iopub.status.busy":"2026-05-13T08:48:15.211362Z","iopub.status.idle":"2026-05-13T08:48:17.285163Z","shell.execute_reply":"2026-05-13T08:48:17.2838Z"},"papermill":{"duration":2.084547,"end_time":"2026-05-13T08:48:17.287555+00:00","exception":false,"start_time":"2026-05-13T08:48:15.203008+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["==================================================\n","BASELINE MODEL — Standard Classification\n","==================================================\n","AUC-ROC: 0.5201\n","\n","PROBLEM WITH THIS APPROACH:\n","→ This model predicts WHO will convert\n","→ It does NOT predict WHO will convert BECAUSE of the email\n","→ It cannot identify Sleeping Dogs\n","→ It cannot distinguish Persuadables from Sure Things\n","→ Targeting top scorers wastes budget on Sure Things\n","→ We need uplift scores, not conversion scores\n","\n"]}],"source":["from sklearn.ensemble import RandomForestClassifier\n","from sklearn.metrics import roc_auc_score\n","\n","# Standard prediction model — ignores treatment\n","# This is what most students would build\n","baseline = RandomForestClassifier(\n","    n_estimators=100,\n","    random_state=42,\n","    n_jobs=-1\n",")\n","baseline.fit(X_train, y_train)\n","baseline_probs = baseline.predict_proba(X_test)[:, 1]\n","\n","print(\"=\" * 50)\n","print(\"BASELINE MODEL — Standard Classification\")\n","print(\"=\" * 50)\n","print(f\"AUC-ROC: {roc_auc_score(y_test, baseline_probs):.4f}\")\n","print(\"\"\"\n","PROBLEM WITH THIS APPROACH:\n","→ This model predicts WHO will convert\n","→ It does NOT predict WHO will convert BECAUSE of the email\n","→ It cannot identify Sleeping Dogs\n","→ It cannot distinguish Persuadables from Sure Things\n","→ Targeting top scorers wastes budget on Sure Things\n","→ We need uplift scores, not conversion scores\n","\"\"\")"]},{"cell_type":"code","execution_count":10,"id":"ccf911ea","metadata":{"execution":{"iopub.execute_input":"2026-05-13T08:48:17.301915Z","iopub.status.busy":"2026-05-13T08:48:17.301219Z","iopub.status.idle":"2026-05-13T08:48:18.969038Z","shell.execute_reply":"2026-05-13T08:48:18.967715Z"},"papermill":{"duration":1.677746,"end_time":"2026-05-13T08:48:18.97141+00:00","exception":false,"start_time":"2026-05-13T08:48:17.293664+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["==================================================\n","T-LEARNER (Two-Model Approach)\n","==================================================\n","Mean uplift score:  0.0037\n","Max uplift score:   0.7700\n","Min uplift score:   -0.5000\n","\n","Customers with NEGATIVE uplift (Sleeping Dogs): 918\n","Customers with POSITIVE uplift (Persuadables):  1536\n"]}],"source":["# T-Learner: train separate models for treatment and control\n","# Uplift = P(convert | treated) - P(convert | control)\n","\n","# Model 1 — trained ONLY on treatment group\n","model_treatment = RandomForestClassifier(\n","    n_estimators=100, random_state=42, n_jobs=-1\n",")\n","model_treatment.fit(\n","    X_train[t_train == 1],\n","    y_train[t_train == 1]\n",")\n","\n","# Model 2 — trained ONLY on control group\n","model_control = RandomForestClassifier(\n","    n_estimators=100, random_state=42, n_jobs=-1\n",")\n","model_control.fit(\n","    X_train[t_train == 0],\n","    y_train[t_train == 0]\n",")\n","\n","# Uplift score = difference in predicted probabilities\n","prob_treatment = model_treatment.predict_proba(X_test)[:, 1]\n","prob_control   = model_control.predict_proba(X_test)[:, 1]\n","uplift_tlearner = prob_treatment - prob_control\n","\n","print(\"=\" * 50)\n","print(\"T-LEARNER (Two-Model Approach)\")\n","print(\"=\" * 50)\n","print(f\"Mean uplift score:  {uplift_tlearner.mean():.4f}\")\n","print(f\"Max uplift score:   {uplift_tlearner.max():.4f}\")\n","print(f\"Min uplift score:   {uplift_tlearner.min():.4f}\")\n","print(f\"\\nCustomers with NEGATIVE uplift (Sleeping Dogs): \"\n","      f\"{(uplift_tlearner < 0).sum()}\")\n","print(f\"Customers with POSITIVE uplift (Persuadables):  \"\n","      f\"{(uplift_tlearner > 0).sum()}\")"]},{"cell_type":"code","execution_count":11,"id":"3cc892ce","metadata":{"execution":{"iopub.execute_input":"2026-05-13T08:48:18.989468Z","iopub.status.busy":"2026-05-13T08:48:18.988918Z","iopub.status.idle":"20